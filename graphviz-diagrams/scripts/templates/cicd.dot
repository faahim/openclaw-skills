// CI/CD pipeline diagram — var: stages (comma-separated)
digraph cicd {
  rankdir=LR
  node [shape=box style="filled,rounded" fontname="Arial" fontsize=11 fillcolor="#dbeafe"]
  edge [fontname="Arial" fontsize=9 color="#64748b"]
  
  start [label="Git Push" shape=oval fillcolor="#bbf7d0"]
  {{stages}}
  done [label="Live" shape=oval fillcolor="#bbf7d0"]
}
