# Proxmox VE Manager Configuration
# Copy to ~/.proxmox-manager.env and edit

# Proxmox host (include https:// and port)
PROXMOX_HOST="https://192.168.1.100:8006"

# Authentication user
PROXMOX_USER="root@pam"

# Option A: API Token (recommended)
# Create in Proxmox UI: Datacenter → Permissions → API Tokens
PROXMOX_TOKEN_ID=""
PROXMOX_TOKEN_SECRET=""

# Option B: Password (creates ticket per session)
PROXMOX_PASSWORD=""

# Default node name (single-node setups)
PROXMOX_NODE="pve"

# SSL verification (false for self-signed certs)
PROXMOX_VERIFY_SSL="false"

# Optional: Telegram alerts
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
