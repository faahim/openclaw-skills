# Kopia Backup Configuration
# Copy to /etc/kopia-backup.env and edit

# Paths to back up (space-separated)
BACKUP_PATHS="/home /etc"

# Repository password
KOPIA_PASSWORD="change-me-to-a-strong-password"

# Compression: none, gzip, zstd, zstd-fastest, s2-default
COMPRESSION="zstd"

# Parallel upload threads
PARALLEL=4

# --- Notifications (optional, configure one or more) ---

# Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ntfy (https://ntfy.sh)
NTFY_TOPIC=""
NTFY_URL="https://ntfy.sh"

# Generic webhook (Slack, Discord, etc.)
WEBHOOK_URL=""

# Send notification on success too (default: only on failure)
NOTIFY_SUCCESS=false
