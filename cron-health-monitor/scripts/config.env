# Cron Health Monitor — Configuration
# Copy to /opt/cron-health-monitor/config.env and edit

# === Alert Configuration ===

# Telegram (recommended)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Webhook (Slack, Discord, custom)
WEBHOOK_URL=""

# Email (requires sendmail or msmtp)
ALERT_EMAIL=""

# === Behavior ===

# Max log entries per job (older entries pruned automatically)
MAX_LOG_ENTRIES=1000

# Watchdog: alert if job is overdue by this factor of its interval
# e.g., 2 = alert if a daily job hasn't run in 48 hours
OVERDUE_FACTOR=2

# Capture stdout/stderr from wrapped jobs
CAPTURE_OUTPUT=true

# Max captured output lines per stream
MAX_OUTPUT_LINES=50

# Default timeout in seconds (0 = no timeout)
DEFAULT_TIMEOUT=0

# Suppress repeat alerts for this many minutes after first alert
ALERT_COOLDOWN_MINUTES=30
