# Database Backup Configuration
# Copy this file: cp config-template.env backup.env
# Then edit backup.env with your settings

# ─── Database Connection ───
DB_TYPE=postgres          # postgres | mysql | mongo
DB_HOST=localhost
DB_PORT=5432              # 5432 (pg) | 3306 (mysql) | 27017 (mongo)
DB_USER=myuser
DB_PASSWORD=mypassword
DB_NAME=mydb              # Database name (or leave empty + use --all-databases)

# ─── Backup Settings ───
BACKUP_DIR=/backups       # Where to store backup files
COMPRESS=true             # Compress with gzip (recommended)
RETAIN_DAYS=7             # Auto-delete backups older than N days (0 = keep all)
TIMESTAMP_FORMAT="%Y-%m-%d_%H%M%S"

# ─── Cloud Upload (optional — leave UPLOAD_TYPE empty to skip) ───
UPLOAD_TYPE=              # s3 | gcs | b2 | "" (empty = local only)
UPLOAD_BUCKET=
UPLOAD_PREFIX=db-backups/
UPLOAD_REGION=us-east-1   # For S3

# ─── Notifications (optional) ───
NOTIFY_ON_SUCCESS=false
NOTIFY_ON_FAILURE=true
NOTIFY_WEBHOOK=           # Slack/Discord webhook URL
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Advanced ───
EXTRA_DUMP_ARGS=          # Extra args for pg_dump/mysqldump/mongodump
